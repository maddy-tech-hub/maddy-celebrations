{
  "name": "maddy-celebrations",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite --open",
    "start:dev": "vite",
    "build": "node ./scripts/build.js",
    "build:app": "tsc -b && vite build",
    "lint": "npx eslint src --ext .ts,.tsx",
    "lint:fix": "npx eslint src --ext .ts,.tsx --fix",
    "prettier": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --check",
    "prettier:fix": "prettier \"src/**/*.{ts,tsx,js,jsx}\" --write",
    "lint:all": "npm run lint && npm run prettier:fix",
    "test": "npx jest --passWithNoTests",
    "test:coverage": "npx jest --coverage --watchAll=false --passWithNoTests",
    "clean": "rimraf dist",
    "lint-staged": "lint-staged",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-router-dom": "^7.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write"
    ]
  }
}
